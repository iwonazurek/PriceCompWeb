@model IEnumerable<Product>

@{
    ViewData["Title"] = "Produkty";
}

<section class="container py-5">
    <div class="section-heading">
        <h1>Produkty</h1>
        <a class="btn btn-primary" asp-action="CreateProduct">Dodaj produkt</a>
    </div>
    <partial name="_AdminMessage" />
    <div class="table-responsive data-surface">
        <table class="table align-middle">
            <thead><tr><th>Nazwa</th><th>Kategoria</th><th>Ilosc</th><th></th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Category</td>
                    <td>@item.Quantity @item.UnitName</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="EditProduct" asp-route-id="@item.Id">Edytuj</a>
                        <form asp-action="DeleteProduct" asp-route-id="@item.Id" method="post" class="d-inline" data-confirm="Usunac produkt?">
                            <button class="btn btn-sm btn-outline-danger" type="submit">Usun</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
